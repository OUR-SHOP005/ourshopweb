{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "build": {
    "src": "client/",
    "use": "@vercel/static-build",
    "config": {
      "distDir": "dist"           // ✅ Ensure Vercel uses the dist folder
    }
  },
  "routes": [
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ]
}
